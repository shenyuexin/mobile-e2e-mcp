  listDevices: boolean;
  measureAndroidPerformance: boolean;
  measureIosPerformance: boolean;
  performActionWithEvidence: boolean;
  autoRemediate: boolean;
  rankFailureCandidates: boolean;
  recordScreen: boolean;
