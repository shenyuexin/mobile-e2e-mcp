    ],
  },
};

function withCiEnv<T>(value: string | undefined, callback: () => T): T {
  const originalCi = process.env.CI;
  if (value === undefined) {
    delete process.env.CI;
  } else {
    process.env.CI = value;
  }

  try {
    return callback();
  } finally {
    if (originalCi === undefined) {
      delete process.env.CI;
    } else {
      process.env.CI = originalCi;
    }
  }
}

